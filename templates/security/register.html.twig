{% extends 'base.html.twig' %}

{% block title %}Inscription - EduTrip{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-body p-5">
                        <h1 class="text-center mb-4">Inscription</h1>

                        {{ form_start(registrationForm, {'attr': {'class': 'needs-validation'}}) }}
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    {{ form_label(registrationForm.prenom, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(registrationForm.prenom) }}
                                </div>
                                <div class="col-md-6 mb-3">
                                    {{ form_label(registrationForm.nom, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control'}}) }}
                                    {{ form_errors(registrationForm.nom) }}
                                </div>
                            </div>

                            <div class="mb-3">
                                {{ form_label(registrationForm.mail, 'Email', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.mail, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(registrationForm.mail) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(registrationForm.tel, 'Téléphone', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.tel, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(registrationForm.tel) }}
                            </div>

                            <div class="mb-3">
                                {{ form_label(registrationForm.password, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.password, {'attr': {'class': 'form-control'}}) }}
                                {{ form_errors(registrationForm.password) }}
                            </div>

                            <div class="mb-4">
                                {{ form_label(registrationForm.role, 'Type de compte', {'label_attr': {'class': 'form-label'}}) }}
                                {{ form_widget(registrationForm.role, {'attr': {'class': 'form-select'}}) }}
                                {{ form_errors(registrationForm.role) }}
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg">S'inscrire</button>
                            </div>
                        {{ form_end(registrationForm) }}

                        <div class="text-center mt-4">
                            <p>Déjà inscrit ? <a href="{{ path('app_login') }}">Connectez-vous ici</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %} 