{% extends 'base.html.twig' %}

{% block title %}Avis - EduTrip{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Avis des utilisateurs</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_avis_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Ajouter un avis
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% if avis|length > 0 %}
        <div class="row">
            {% for avi in avis %}
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <h5 class="card-title mb-0">{{ avi.user.prenom }} {{ avi.user.nom }}</h5>
                                    <small class="text-muted">{{ avi.createdAt|date('d/m/Y') }}</small>
                                </div>
                                <div class="rating">
                                    {% for i in 1..5 %}
                                        {% if i <= avi.rating %}
                                            <i class="fas fa-star text-warning"></i>
                                        {% else %}
                                            <i class="far fa-star text-warning"></i>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                            <p class="card-text">{{ avi.comment }}</p>
                            
                            {% if app.user and app.user == avi.user %}
                                <div class="mt-3">
                                    <a href="{{ path('app_avis_edit', {'id': avi.id}) }}" class="btn btn-sm btn-outline-primary me-2">
                                        <i class="fas fa-edit me-1"></i>Modifier
                                    </a>
                                    <form method="post" action="{{ path('app_avis_delete', {'id': avi.id}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet avis ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ avi.id) }}">
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash-alt me-1"></i>Supprimer
                                        </button>
                                    </form>
                                </div>
                        {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>Aucun avis n'a encore été publié. Soyez le premier à partager votre expérience !
        </div>
    {% endif %}
</div>
{% endblock %}
