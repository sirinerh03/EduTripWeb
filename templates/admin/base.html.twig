<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Administration{% endblock %} - EduTrip</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        <div class="container-fluid">
            <div class="row">
                <!-- Sidebar -->
                <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-dark sidebar collapse">
                    <div class="position-sticky pt-3">
                        <ul class="nav flex-column">
                            <li class="nav-item mb-4">
                                <a class="nav-link text-white" href="{{ path('admin_dashboard') }}">
                                    <i class="fas fa-graduation-cap fa-2x me-2"></i>
                                    <span class="fs-4">EduTrip Admin</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white {{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}" href="{{ path('admin_dashboard') }}">
                                    <i class="fas fa-tachometer-alt me-2"></i>
                                    Tableau de bord
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_user' ? 'active' : '' }}" href="{{ path('app_user_index') }}">
                                    <i class="fas fa-users me-2"></i>
                                    Utilisateurs
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white {{ app.request.get('_route') starts with 'app_avis' ? 'active' : '' }}" href="{{ path('app_avis_index') }}">
                                    <i class="fas fa-star me-2"></i>
                                    Avis
                                </a>
                            </li>
                            <li class="nav-item mt-4">
                                <a class="nav-link text-white" href="{{ path('app_home') }}">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Retour au site
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt me-2"></i>
                                    Déconnexion
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1>{% block page_title %}{% endblock %}</h1>
                        <div class="btn-toolbar mb-2 mb-md-0">
                            {% block page_actions %}{% endblock %}
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger ms-2">
                                <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                            </a>
                        </div>
                    </div>

                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                // Confirm delete actions
                document.addEventListener('DOMContentLoaded', function() {
                    const deleteButtons = document.querySelectorAll('[data-confirm]');
                    deleteButtons.forEach(button => {
                        button.addEventListener('click', function(e) {
                            if (!confirm(this.dataset.confirm || 'Êtes-vous sûr de vouloir supprimer cet élément ?')) {
                                e.preventDefault();
                            }
                        });
                    });
                });
            </script>
        {% endblock %}
    </body>
</html> 